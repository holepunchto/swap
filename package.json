{
  "name": "swap",
  "version": "0.0.2",
  "description": "Atomically swap two filesystem paths",
  "private": true,
  "bin": "bin.mjs",
  "upgrade": "pear://swapb14acos6iasoz5jg8bj46zt8emdk9rmm4n9j18mtjmwbqmwo",
  "scripts": {
    "format": "prettier . --write && lunte --fix",
    "test": "brittle-bare test/index.js",
    "lint": "prettier . --check && lunte",
    "start": "bare bin.mjs --no-updates",
    "make": "node scripts/make.js",
    "make:darwin-arm64": "bare-build --name swap --standalone --host darwin-arm64 --out ./out/darwin-arm64 bin.mjs",
    "make:darwin-x64": "bare-build --name swap --standalone --host darwin-x64 --out ./out/darwin-x64 bin.mjs",
    "make:linux-arm64": "bare-build --name swap --standalone --host linux-arm64 --out ./out/linux-arm64 bin.mjs",
    "make:linux-x64": "bare-build --name swap --standalone --host linux-x64 --out ./out/linux-x64 bin.mjs",
    "make:win32-arm64": "bare-build --name swap --standalone --host win32-arm64 --out ./out/win32-arm64 bin.mjs",
    "make:win32-x64": "bare-build --name swap --standalone --host win32-x64 --out ./out/win32-x64 bin.mjs"
  },
  "dependencies": {
    "bare-console": "^6.2.0",
    "bare-daemon": "^1.2.4",
    "bare-file-logger": "^1.2.1",
    "bare-fs": "^4.7.2",
    "bare-os": "^3.9.0",
    "bare-path": "^3.0.0",
    "bare-storage": "^1.1.0",
    "corestore": "^7.9.2",
    "fs-native-extensions": "^1.5.0",
    "hyperswarm": "^4.17.0",
    "paparam": "^1.10.1",
    "pear-runtime": "^1.1.4",
    "ready-resource": "^1.2.0",
    "which-runtime": "^1.4.0"
  },
  "devDependencies": {
    "bare-build": "^1.0.1",
    "bare-runtime": "^1.29.5",
    "brittle": "^3.19.0",
    "lunte": "^1.2.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^2.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/holepunchto/hello-pear-bare.git"
  },
  "author": "Holepunch Inc",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/hello-pear-bare/issues"
  }
}
